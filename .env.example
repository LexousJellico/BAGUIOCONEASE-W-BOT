APP_NAME="BCCC EASE"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=Asia/Manila

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local XAMPP / Hostinger MySQL defaults.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bccc_ease
DB_USERNAME=root
DB_PASSWORD=

# Use database locally because the project includes Laravel's session/cache/job tables.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=bccc_ease

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=info@baguioccc-ease.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@baguioccc-ease.com"
MAIL_FROM_NAME="${APP_NAME}"
# xyrusstacruz113@gmail.com

# Google OAuth login. Leave blank if Google login is not enabled yet.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Optional Gemini AI for the client System Bot. Leave blank to use the built-in local BCCC EASE knowledge fallback.
# Get the key from Google AI Studio, then set this only in your real .env file.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# General questions can use Gemini's broad knowledge. BCCC and private facts remain system-grounded.
GEMINI_GENERAL_KNOWLEDGE=true
GEMINI_GENERAL_MODEL=gemini-2.5-pro
# Google Search grounding improves current-information answers and may add API usage.
GEMINI_GOOGLE_SEARCH=true
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_TIMEOUT=15

# MICE / survey proof helper links used by booking forms and QR fallback UI.
SURVEY_URL=
SURVEY_QR_IMAGE_URL=/qr.png

# Optional S3 mirror for survey proof images and other uploaded proof files.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Telescope should usually be disabled in production/shared hosting.
TELESCOPE_ENABLED=false
TELESCOPE_PATH=telescope

VITE_APP_NAME="${APP_NAME}"
